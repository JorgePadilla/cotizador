<%= form_with(model: invoice, class: "space-y-6", data: { 
      controller: "invoice-form",
      invoice_form_default_tax_percentage_value: current_user&.default_tax || 15,
      invoice_form_invoice_persisted_value: invoice.persisted?
    }) do |form| %>
  <% if invoice.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
      <strong class="font-bold"><%= t('errors.title') %>:</strong>
      <span class="block sm:inline"><%= t('errors.messages.prohibited_save', count: invoice.errors.count) %></span>
      <ul class="list-disc list-inside mt-2">
        <% invoice.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if fiscal_mode? %>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <div class="flex-1">
          <h3 class="text-sm font-semibold text-blue-900"><%= t("invoices.sar.fiscal_mode_title") %></h3>
          <p class="text-xs text-blue-800 mt-1"><%= t("invoices.sar.fiscal_mode_help") %></p>
          <% if correlativo_preview %>
            <p class="text-xs text-blue-900 mt-2 font-mono">
              <%= t("invoices.sar.next_correlativo_preview") %>: <strong><%= correlativo_preview %></strong>
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="bg-white shadow overflow-hidden sm:rounded-lg p-6 mb-4">
      <h3 class="text-sm font-medium text-gray-900 mb-3"><%= t("invoices.sar.fiscal_section") %></h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <%= form.label :establishment_id, t("invoices.sar.establishment"), class: "block text-sm font-medium text-gray-700" %>
          <%= form.collection_select :establishment_id, establishments, :id, ->(e) { "#{e.codigo} — #{e.nombre}" },
                                     { include_blank: true },
                                     { class: "mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm sm:text-sm",
                                       disabled: invoice.immutable? } %>
        </div>
        <div>
          <%= form.label :emission_point_id, t("invoices.sar.emission_point"), class: "block text-sm font-medium text-gray-700" %>
          <% emission_point_choices = establishments.flat_map { |e| e.emission_points.active.map { |ep| [ "#{e.codigo}-#{ep.codigo}", ep.id ] } } %>
          <%= form.select :emission_point_id, emission_point_choices,
                          { include_blank: true },
                          { class: "mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm sm:text-sm",
                            disabled: invoice.immutable? } %>
        </div>
        <div>
          <%= form.label :document_type_id, t("invoices.sar.document_type"), class: "block text-sm font-medium text-gray-700" %>
          <%= form.collection_select :document_type_id, document_types, :id, :name,
                                     { include_blank: true },
                                     { class: "mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm sm:text-sm",
                                       disabled: invoice.immutable? } %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :invoice_number, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :invoice_number,
                            class: "mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md",
                            readonly: invoice.fiscal? || invoice.immutable? %>
      </div>

      <div>
        <%= form.label :invoice_date, class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :invoice_date,
                            class: "mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md",
                            placeholder: "YYYY-MM-DD",
                            pattern: "[0-9]{4}-[0-9]{2}-[0-9]{2}",
                            title: "Use format YYYY-MM-DD" %>
      </div>

      <div>
        <%= form.label :client_id, class: "block text-sm font-medium text-gray-700" %>
        <%= form.collection_select :client_id, clients, :id, :name,
                                  { include_blank: t('invoices.select_client') },
                                  { class: "mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" } %>
      </div>

      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :status,
                        [[t('invoices.statuses.draft'), 'draft'], [t('invoices.statuses.pending'), 'pending'], [t('invoices.statuses.paid'), 'paid'], [t('invoices.statuses.cancelled'), 'cancelled']],
                        { include_blank: false },
                        { class: "mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                          data: { action: "change->invoice-form#togglePaymentMethod" } } %>
      </div>

      <div id="payment-method-field" class="<%= invoice.status == 'paid' ? '' : 'hidden' %>">
        <%= form.label :payment_method, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :payment_method,
                        [[t('invoices.payment_methods.cash'), 'cash'], [t('invoices.payment_methods.credit_card'), 'credit_card'], [t('invoices.payment_methods.bank_transfer'), 'bank_transfer'], [t('invoices.payment_methods.check'), 'check']],
                        { include_blank: t('invoices.select_payment_method') },
                        { class: "mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                          data: { invoice_form_target: "paymentMethod" } } %>
      </div>
    </div>
  </div>

  <h3 class="text-lg font-medium text-gray-900 mt-8 mb-4"><%= t('invoices.items_section') %></h3>
  <div class="bg-white shadow overflow-hidden sm:rounded-lg p-6">
    <div class="mb-4">
      <div id="invoice-items" data-invoice-form-target="itemsContainer">
        <% if invoice.invoice_items.empty? %>
          <div class="invoice-item-fields grid grid-cols-1 md:grid-cols-5 gap-4 border-b pb-4 mb-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700"><%= t('invoices.item.product') %></label>
              <select name="invoice[invoice_items_attributes][0][product_id]" 
                      class="product-select mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                      data-action="change->invoice-form#updatePrice">
                <option value=""><%= t('invoices.select_product') %></option>
                <% Current.organization.products.each do |product| %>
                  <option value="<%= product.id %>" data-price="<%= product.price %>"><%= product.name %> - <%= format_currency(product.price, Current.organization) %></option>
                <% end %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700"><%= t('invoices.item.quantity') %></label>
              <input type="number" 
                     name="invoice[invoice_items_attributes][0][quantity]" 
                     min="1" 
                     value="1" 
                     class="quantity-input mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                     data-action="input->invoice-form#updateTotals">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700"><%= t('invoices.item.unit_price') %></label>
              <input type="number" 
                     step="0.01" 
                     name="invoice[invoice_items_attributes][0][unit_price]" 
                     class="price-input mt-1 block w-full py-2 px-3 border border-gray-300 bg-gray-50 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" 
                     readonly>
            </div>
            <div class="flex items-end">
              <button type="button" 
                      class="remove-item-btn mt-1 bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded"
                      data-action="click->invoice-form#removeItem">
<%= t('actions.remove_item') %>
              </button>
            </div>
          </div>
        <% else %>
          <% invoice.invoice_items.each_with_index do |item, index| %>
            <div class="invoice-item-fields grid grid-cols-1 md:grid-cols-5 gap-4 border-b pb-4 mb-4">
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700"><%= t('invoices.item.product') %></label>
                <select name="invoice[invoice_items_attributes][#{index}][product_id]" 
                        class="product-select mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                        data-action="change->invoice-form#updatePrice">
                  <option value=""><%= t('invoices.select_product') %></option>
                  <% Current.organization.products.each do |product| %>
                    <option value="<%= product.id %>" data-price="<%= product.price %>" <%= 'selected' if product.id == item.product_id %>>
                      <%= product.name %> - <%= format_currency(product.price, Current.organization) %>
                    </option>
                  <% end %>
                </select>
                <%= hidden_field_tag "invoice[invoice_items_attributes][#{index}][id]", item.id if item.persisted? %>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700"><%= t('invoices.item.quantity') %></label>
                <%= number_field_tag "invoice[invoice_items_attributes][#{index}][quantity]", 
                                    item.quantity, 
                                    min: 1, 
                                    class: "quantity-input mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                                    data: { action: "input->invoice-form#updateTotals" } %>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700"><%= t('invoices.item.unit_price') %></label>
                <%= number_field_tag "invoice[invoice_items_attributes][#{index}][unit_price]", 
                                    item.unit_price, 
                                    step: "0.01", 
                                    readonly: true,
                                    class: "price-input mt-1 block w-full py-2 px-3 border border-gray-300 bg-gray-50 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
              </div>
              <div class="flex items-end">
                <button type="button" 
                        class="remove-item-btn mt-1 bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded"
                        data-action="click->invoice-form#removeItem">
  <%= t('actions.remove_item') %>
                </button>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <button type="button" 
              class="mt-4 bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded"
              data-invoice-form-target="addButton"
              data-action="click->invoice-form#addItem">
<%= t('invoices.add_item') %>
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <div>
        <%= form.label :subtotal, class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :subtotal, 
                             step: "0.01", 
                             class: "mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md", 
                             readonly: true,
                             data: { invoice_form_target: "subtotal" } %>
      </div>

      <div>
        <%= form.label :tax, class: "block text-sm font-medium text-gray-700" %>
        <% default_tax_percentage = current_user&.default_tax || 15 %>
        <%= form.number_field :tax, 
                             value: default_tax_amount, 
                             step: "1", 
                             data: { 
                               default_tax_percentage: default_tax_percentage,
                               invoice_form_target: "tax",
                               action: "input->invoice-form#updateTotals"
                             },
                             class: "mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md" %>
      </div>

      <div>
        <%= form.label :total, class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :total, 
                             step: "0.01", 
                             class: "mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md", 
                             readonly: true,
                             data: { invoice_form_target: "total" } %>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-3 mt-8">
    <%= link_to t('actions.cancel'), invoices_path, class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" %>
    <%= form.submit class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded cursor-pointer" %>
  </div>
<% end %>
