<nav class="bg-white shadow-sm rounded-lg p-4 sticky top-6 text-sm">
  <div class="mb-6">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"><%= t("settings.sidebar.personal") %></h2>
    <ul class="space-y-1">
      <% personal_items.each do |i| %>
        <li>
          <%= link_to i[:path],
                      class: "flex items-center gap-2 px-3 py-2 rounded-md #{i[:active] ? 'bg-blue-50 text-blue-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <%= sidebar_icon(i[:icon]) %>
            <%= i[:label] %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="mb-6">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"><%= t("settings.sidebar.company") %></h2>
    <ul class="space-y-1">
      <% company_items.each do |i| %>
        <li>
          <%= link_to i[:path],
                      class: "flex items-center gap-2 px-3 py-2 rounded-md #{i[:active] ? 'bg-blue-50 text-blue-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <%= sidebar_icon(i[:icon]) %>
            <%= i[:label] %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <% if admin_items.any? %>
    <div>
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2"><%= t("settings.sidebar.administration") %></h2>
      <ul class="space-y-1">
        <% admin_items.each do |i| %>
          <li>
            <%= link_to i[:path],
                        class: "flex items-center gap-2 px-3 py-2 rounded-md #{i[:active] ? 'bg-blue-50 text-blue-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <%= sidebar_icon(i[:icon]) %>
              <%= i[:label] %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</nav>
