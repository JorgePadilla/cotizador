<% content_for :title, t("sar.establishments.title") %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("sar.establishments.title") %></h1>
    <%= link_to t("sar.establishments.new"), new_sar_establishment_path,
                class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-2 rounded-md" %>
  </div>

  <% if @establishments.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul class="divide-y divide-gray-200">
        <% @establishments.each do |est| %>
          <li class="px-4 py-4 hover:bg-gray-50">
            <%= link_to sar_establishment_path(est), class: "flex justify-between items-center" do %>
              <div>
                <p class="text-sm font-medium text-blue-600"><%= est.codigo %> — <%= est.nombre %></p>
                <p class="text-xs text-gray-500"><%= est.address %></p>
              </div>
              <span class="<%= est.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %> text-xs px-2 py-1 rounded">
                <%= est.active? ? t("common.yes") : t("common.no") %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <p class="text-gray-500 text-center py-12"><%= t("sar.establishments.empty") %></p>
  <% end %>
</div>
