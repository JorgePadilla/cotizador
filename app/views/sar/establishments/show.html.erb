<% content_for :title, "#{@establishment.codigo} — #{@establishment.nombre}" %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @establishment.codigo %> — <%= @establishment.nombre %></h1>
      <p class="text-sm text-gray-600"><%= @establishment.address %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to t("actions.edit"), edit_sar_establishment_path(@establishment),
                  class: "px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded-md text-sm" %>
      <%= button_to t("actions.delete"), sar_establishment_path(@establishment), method: :delete,
                    data: { turbo_confirm: t("actions.confirm_delete") },
                    class: "px-3 py-2 bg-red-100 hover:bg-red-200 text-red-700 rounded-md text-sm" %>
    </div>
  </div>

  <div class="bg-white shadow sm:rounded-md p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-gray-900"><%= t("sar.emission_points.title") %></h2>
      <%= link_to t("sar.emission_points.new"), new_sar_establishment_emission_point_path(@establishment),
                  class: "px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm rounded-md" %>
    </div>

    <% if @emission_points.any? %>
      <ul class="divide-y divide-gray-200">
        <% @emission_points.each do |ep| %>
          <li class="py-3 flex justify-between">
            <%= link_to "#{ep.codigo} — #{ep.descripcion}",
                        sar_establishment_emission_point_path(@establishment, ep),
                        class: "text-blue-600 hover:underline" %>
            <span class="text-xs text-gray-500"><%= ep.active? ? t("common.yes") : t("common.no") %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500 text-center py-6"><%= t("sar.emission_points.empty") %></p>
    <% end %>
  </div>
</div>
