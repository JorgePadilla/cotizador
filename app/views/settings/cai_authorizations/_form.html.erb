<%= form_with model: [ :settings, cai_authorization ], local: true, class: "space-y-4" do |f| %>
  <% if cai_authorization.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% cai_authorization.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :emission_point_id, t("sar.cai_authorizations.attributes.emission_point"), class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :emission_point_id, @emission_points,
                            :id, ->(ep) { "#{ep.establishment.codigo}-#{ep.codigo} (#{ep.descripcion})" },
                            { include_blank: true },
                            { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm", required: true } %>
  </div>

  <div>
    <%= f.label :document_type_id, t("sar.cai_authorizations.attributes.document_type"), class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :document_type_id, @document_types, :id, :name,
                            { include_blank: true },
                            { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm", required: true } %>
  </div>

  <div>
    <%= f.label :cai, t("sar.cai_authorizations.attributes.cai"), class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :cai, required: true, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm font-mono" %>
    <p class="text-xs text-gray-500"><%= t("sar.cai_authorizations.cai_help") %></p>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :rango_inicial, t("sar.cai_authorizations.attributes.rango_inicial"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :rango_inicial, required: true, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :rango_final, t("sar.cai_authorizations.attributes.rango_final"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :rango_final, required: true, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :fecha_limite_emision, t("sar.cai_authorizations.attributes.fecha_limite_emision"), class: "block text-sm font-medium text-gray-700" %>
    <%= f.date_field :fecha_limite_emision, required: true, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :fecha_resolucion, t("sar.cai_authorizations.attributes.fecha_resolucion"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.date_field :fecha_resolucion, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :numero_resolucion, t("sar.cai_authorizations.attributes.numero_resolucion"), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :numero_resolucion, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
  </div>

  <div class="flex items-center">
    <%= f.check_box :active, class: "h-4 w-4 text-blue-600 border-gray-300 rounded" %>
    <%= f.label :active, t("sar.cai_authorizations.attributes.active"), class: "ml-2 block text-sm text-gray-700" %>
  </div>

  <div class="flex justify-end gap-3 pt-4">
    <%= link_to t("actions.cancel"), settings_fiscal_path,
                class: "px-4 py-2 border border-gray-300 rounded-md text-sm" %>
    <%= f.submit t("actions.save"), class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md text-sm" %>
  </div>
<% end %>
