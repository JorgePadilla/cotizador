<% content_for :title, t("settings.organization.edit_title") %>

<%= form_with model: @organization, url: settings_organization_path, method: :patch, local: true, class: "space-y-6" do |f| %>
  <% if @organization.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-3 py-2 rounded text-sm">
      <ul class="list-disc list-inside">
        <% @organization.errors.full_messages.each { |m| %><li><%= m %></li><% } %>
      </ul>
    </div>
  <% end %>

  <%= settings_card t("settings.organization.fiscal_identity"), subtitle: t("settings.organization.fiscal_identity_help") do %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :name, t("activerecord.attributes.organization.name"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, required: true, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :nombre_comercial, t("activerecord.attributes.organization.nombre_comercial"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :nombre_comercial, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :rtn, t("activerecord.attributes.organization.rtn"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :rtn, pattern: "\\d{14}", maxlength: 14,
                          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm font-mono" %>
        <p class="text-xs text-gray-500 mt-1"><%= t("settings.organization.rtn_help") %></p>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :casa_matriz_address, t("activerecord.attributes.organization.casa_matriz_address"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :casa_matriz_address, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
    </div>
  <% end %>

  <%= settings_card t("settings.organization.contact_info") do %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <%= f.label :address, t("activerecord.attributes.organization.address"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :address, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :phone, t("activerecord.attributes.organization.phone"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :email, t("activerecord.attributes.organization.email"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
    </div>
  <% end %>

  <%= settings_card t("settings.organization.regional") do %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :currency, t("activerecord.attributes.organization.currency"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :currency, [ [ "HNL", "HNL" ], [ "USD", "USD" ], [ "EUR", "EUR" ] ],
                     { include_blank: true },
                     class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
      <div>
        <%= f.label :language, t("activerecord.attributes.organization.language"), class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :language, [ [ t("languages.es"), "es" ], [ t("languages.en"), "en" ] ],
                     { include_blank: true },
                     class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
      </div>
    </div>
  <% end %>

  <div class="flex justify-end gap-3">
    <%= link_to t("actions.cancel"), settings_organization_path,
                class: "px-4 py-2 border border-gray-300 rounded-md text-sm" %>
    <%= f.submit t("actions.save"),
                 class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md text-sm" %>
  </div>
<% end %>
