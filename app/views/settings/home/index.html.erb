<% content_for :title, t("settings.home.title") %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= t("settings.home.title") %></h1>
  <p class="text-sm text-gray-500 mb-8"><%= t("settings.home.subtitle") %></p>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    <% @menu_items.each do |item| %>
      <%= link_to item[:path],
                  class: "group flex flex-col items-center text-center p-6 bg-white rounded-lg border border-gray-200 hover:border-blue-300 hover:shadow-md transition" do %>
        <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center mb-3 group-hover:bg-blue-100">
          <%= settings_card_icon(item[:icon]) %>
        </div>
        <span class="text-sm font-medium text-gray-900"><%= item[:label] %></span>
      <% end %>
    <% end %>

    <%= button_to session_path, method: :delete,
                  form: { class: "contents" },
                  class: "group flex flex-col items-center text-center p-6 bg-white rounded-lg border border-gray-200 hover:border-red-300 hover:shadow-md transition w-full cursor-pointer" do %>
      <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mb-3 group-hover:bg-red-100">
        <%= settings_card_icon("logout", color: "red") %>
      </div>
      <span class="text-sm font-medium text-gray-900"><%= t("settings.home.items.sign_out") %></span>
    <% end %>
  </div>
</div>
