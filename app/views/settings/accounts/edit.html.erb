<% content_for :title, t("settings.account.edit_title") %>

<%= settings_card t("settings.account.personal_data") do %>
  <%= form_with model: @user, url: settings_account_path, method: :patch, local: true, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-3 py-2 rounded text-sm">
        <ul class="list-disc list-inside">
          <% @user.errors.full_messages.each { |m| %><li><%= m %></li><% } %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, required: true, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :email_address, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email_address, required: true, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>

    <div class="flex justify-end gap-3 pt-2">
      <%= link_to t("actions.cancel"), settings_account_path,
                  class: "px-4 py-2 border border-gray-300 rounded-md text-sm" %>
      <%= f.submit t("actions.save"),
                   class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md text-sm" %>
    </div>
  <% end %>
<% end %>
