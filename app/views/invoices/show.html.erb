<div class="w-full max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900"><%= t('invoices.title') %> <%= @invoice.invoice_number %></h1>
    <div class="flex space-x-3">
      <%= link_to t('actions.back'), invoices_path, class: "text-blue-600 hover:text-blue-800" %>
      <%= link_to t('actions.edit'), edit_invoice_path(@invoice), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8">
    <div class="px-4 py-5 sm:px-6 flex justify-between">
      <div>
        <h3 class="text-lg leading-6 font-medium text-gray-900"><%= t('invoices.details') %></h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500"><%= t('invoices.details_description') %></p>
      </div>
      <% status_class = case @invoice.status 
         when 'draft' then 'bg-gray-100 text-gray-800'
         when 'pending' then 'bg-yellow-100 text-yellow-800'
         when 'paid' then 'bg-green-100 text-green-800'
         when 'cancelled' then 'bg-red-100 text-red-800'
         else 'bg-gray-100 text-gray-800'
         end %>
      <span class="px-3 py-1 inline-flex text-sm leading-5 font-semibold rounded-full <%= status_class %>">
        <%= t("invoices.statuses.#{@invoice.status}") %>
      </span>
    </div>
    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('invoices.attributes.invoice_number') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @invoice.invoice_number %></dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('invoices.attributes.client') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
            <%= link_to @invoice.client.name, client_path(@invoice.client), class: "text-blue-600 hover:text-blue-800" %>
          </dd>
        </div>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('invoices.attributes.date') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= l(@invoice.invoice_date, format: :long) %></dd>
        </div>
        <% if @invoice.status == 'paid' %>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500"><%= t('invoices.attributes.payment_method') %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <% payment_method_display = if @invoice.payment_method.present?
                                           if @invoice.payment_method.is_a?(String)
                                             t("invoices.payment_methods.#{@invoice.payment_method}")
                                           elsif @invoice.payment_method.is_a?(Hash)
                                             first_key = @invoice.payment_method.keys.first
                                             t("invoices.payment_methods.#{first_key}")
                                           else
                                             t('common.not_available')
                                           end
                                         else
                                           t('common.not_available')
                                         end %>
              <%= payment_method_display %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t('invoices.items') %></h3>
  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('products.title') %></th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('invoices.quantity') %></th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('invoices.attributes.unit_price') %></th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('invoices.attributes.total') %></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if @invoice_items.any? %>
          <% @invoice_items.each do |item| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= link_to item.product.name, product_path(item.product), class: "text-blue-600 hover:text-blue-800" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= item.quantity %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= format_currency(item.unit_price) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= format_currency(item.total) %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center"><%= t('invoices.no_items') %></td>
          </tr>
        <% end %>
      </tbody>
      <tfoot class="bg-gray-50">
        <tr>
          <td colspan="3" class="px-6 py-4 text-right text-sm font-medium text-gray-500"><%= t('invoices.attributes.subtotal') %>:</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= format_currency(@invoice.subtotal) %></td>
        </tr>
        <tr>
          <td colspan="3" class="px-6 py-4 text-right text-sm font-medium text-gray-500"><%= t('invoices.attributes.tax') %>:</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= format_currency(@invoice.tax) %></td>
        </tr>
        <tr>
          <td colspan="3" class="px-6 py-4 text-right text-sm font-medium text-gray-900"><%= t('invoices.attributes.total') %>:</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900"><%= format_currency(@invoice.total) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="flex justify-between">
    <%= button_to invoice_path(@invoice), method: :delete, class: "bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded flex items-center", form: { data: { turbo_confirm: t('invoices.delete_confirm') } } do %>
      <svg class="-ml-0.5 mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      <%= t('invoices.delete') %>
    <% end %>

    <div class="flex space-x-3">
      <%= link_to pdf_invoice_path(@invoice, format: :pdf), class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded flex items-center whitespace-nowrap", target: "_blank" do %>
        <svg class="-ml-0.5 mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        <%= t('quotes.print_to_pdf') %>
      <% end %>
      <%= link_to edit_invoice_path(@invoice), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded flex items-center" do %>
        <svg class="-ml-0.5 mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <%= t('invoices.edit') %>
      <% end %>
    </div>
  </div>
</div>
