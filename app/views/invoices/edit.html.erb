<div class="w-full max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900"><%= t('invoices.edit') %></h1>
    <div class="flex space-x-3">
      <%= link_to t('invoices.back_to_invoice'), invoice_path(@invoice), class: "text-blue-600 hover:text-blue-800" %>
      <%= link_to t('invoices.all_invoices'), invoices_path, class: "text-blue-600 hover:text-blue-800" %>
    </div>
  </div>

  <%= render(InvoiceFormComponent.new(invoice: @invoice, clients: @clients, current_user: Current.user)) %>
</div>
