<div class="w-full max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= t("debit_notes.new") %></h1>
  <p class="text-sm text-gray-600 mb-6">
    <%= t("debit_notes.creating_from") %>
    <%= link_to @debit_note.original_invoice.correlativo,
                invoice_path(@debit_note.original_invoice),
                class: "font-mono text-blue-600 hover:underline" %>
  </p>

  <%= form_with model: @debit_note, local: true, class: "space-y-6" do |form| %>
    <% if @debit_note.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside">
          <% @debit_note.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form.hidden_field :original_invoice_id %>
    <%= form.hidden_field :client_id %>

    <div class="bg-white shadow sm:rounded-lg p-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-3"><%= t("invoices.items") %></h3>
      <% @debit_note.invoice_items.each_with_index do |item, idx| %>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-3 border-b py-2 text-sm">
          <%= hidden_field_tag "debit_note[invoice_items_attributes][#{idx}][product_id]", item.product_id %>
          <%= hidden_field_tag "debit_note[invoice_items_attributes][#{idx}][description]", item.description %>
          <%= hidden_field_tag "debit_note[invoice_items_attributes][#{idx}][unit_price]", item.unit_price %>
          <%= hidden_field_tag "debit_note[invoice_items_attributes][#{idx}][tipo_isv_override]", item.tipo_isv_override %>
          <span class="md:col-span-2"><%= item.product&.name %></span>
          <span><%= t("invoices.quantity") %>:
            <input type="number" name="debit_note[invoice_items_attributes][<%= idx %>][quantity]"
                   value="<%= item.quantity %>" min="1" class="w-20 border rounded px-2 py-1">
          </span>
          <span class="text-right"><%= format_currency(item.unit_price) %></span>
          <span class="text-right font-mono"><%= format_currency(item.total) %></span>
        </div>
      <% end %>
    </div>

    <div class="flex justify-end gap-3">
      <%= link_to t("actions.cancel"), invoice_path(@debit_note.original_invoice),
                  class: "px-4 py-2 border border-gray-300 rounded-md text-sm" %>
      <%= form.submit t("debit_notes.create"),
                      class: "px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-md text-sm font-medium" %>
    </div>
  <% end %>
</div>
